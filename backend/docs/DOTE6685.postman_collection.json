      "name": "Authentication",
      "item": [
        {
          "name": "1. Register User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "let jsonData;",
                  "try {",
                  "    jsonData = pm.response.json();",
                  "} catch (e) {",
                  "    throw new Error('Response body is not valid JSON');",
                  "}",
                  "",
                  "pm.test('Registration successful and userId saved', function () {",
                  "    pm.expect(jsonData.userId, 'Expected userId in response').to.be.a('string').and.not.empty;",
                  "    pm.collectionVariables.set('userId', jsonData.userId);",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Joh123\",\n  \"email\": \"jo23@example.com\",\n  \"phone\": \"\",\n  \"password\": \"password123\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{BaseURL}}/auth/register",
              "host": [
                "{{BaseURL}}"
              ],
              "path": [
                "auth",
                "register"
              ]
            },
            "description": "Register a new user. No role is assigned at this step. Use the returned `userId` to call **Select Role** next.\n\nRequired fields: `name`, `email`, `password`\nOptional: `phone`"
          },
          "response": []
        },
        {
          "name": "2. Select Role",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"{{userId}}\",\n  \"role\": \"STUDENT\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{BaseURL}}/auth/select-role",
              "host": [
                "{{BaseURL}}"
              ],
              "path": [
                "auth",
                "select-role"
              ]
            },
            "description": "Assign a role to a newly registered user. Call this immediately after Register using the `{{userId}}` variable saved by the Register test script.\n\nAvailable roles: `STUDENT`, `PARENT`, `TEACHER`, `SCHOOL_ADMIN`"
          },
          "response": []
        },
        {
          "name": "3. Login User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "let json;",
                  "let token;",
                  "",
                  "pm.test('Response body is valid JSON', function () {",
                  "    pm.expect(function () {",
                  "        json = pm.response.json();",
                  "    }).to.not.throw();",
                  "});",
                  "",
                  "if (json) {",
                  "    token = json.token || json.access_token || json.authToken || json.jwt || (json.data && (json.data.token || json.data.access_token));",
                  "}",
                  "",
                  "pm.test('Token exists in response and is saved', function () {",
                  "    pm.expect(token, 'Expected a token field in the response body').to.be.a('string').and.not.empty;",
                  "",
                  "    if (token) {",
                  "        pm.collectionVariables.set('token', token);",
                  "        pm.expect(pm.collectionVariables.get('token')).to.eql(token);",
                  "    }",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"jo23@example.com\",\n  \"password\": \"password123\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{BaseURL}}/auth/login",
              "host": [
                "{{BaseURL}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            },
            "description": "Login the user if input with correct username and password. Returns with a bearer token for later use. For convenience, the token already retrieved by script already can would be passed to later API calls.\n\nYou may test with different role for some already exists account:\n\n1. Student: [student@school.com](https://mailto:student@school.com)\n    \n2. Parent: [parent@family.com](https://mailto:parent@family.com)\n    \n3. Teacher: [teacher@school.com](https://mailto:teacher@school.com)\n    \n4. School Admin: [admin@school.com](https://mailto:admin@school.com)\n    \n\nWhere the password for all account are: **password123**"
          },
          "response": []
        }
      ]
